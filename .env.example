# API Credentials Template
# ============================
# Copy this file to .env.local and fill in your actual credentials
# The .env.local file will be ignored by git to prevent credential leaks
#
# To get these credentials:
# - YOUTUBE_API_KEY: https://console.developers.google.com/
# - APIFY_TOKEN: https://my.apify.com/account/integrations/api
# - CLAUDE_API_KEY: https://console.anthropic.com/
# - YT_PROXY_* (optional): Proxy servers for YouTube scraping

YOUTUBE_API_KEY=your_youtube_api_key_here
APIFY_TOKEN=your_apify_token_here
CLAUDE_API_KEY=your_claude_api_key_here
YT_PROXY_HTTP=
YT_PROXY_HTTPS=

